{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "autoupdate": true,
  "disabled_providers": [
    "opencode",
    "openai",
    "anthropic",
    "github-copilot",
    "openrouter"
  ],
  "provider": {
    "local": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Local LLM",
      "options": {
        "baseURL": "http://{env:LLM_API_HOST}/v1",
        "apiKey": "local"
      },
      "models": {
        "{env:LLM_MODEL}": {
          "attachment": true,
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          }
        }
      }
    }
  },
  "model": "local/{env:LLM_MODEL}",
  "small_model": "local/{env:LLM_MODEL}",
  "plugin": [
    "{env:HOME}/.config/opencode/plugins/hooks.js"
  ],
  "agent": {
    "build": {
      "permission": {
        "webfetch": "allow",
        "websearch": "allow",
        "codesearch": "allow",
        "external_directory": {
          "/tmp/*": "allow"
        }
      }
    }
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    }
  }
}
